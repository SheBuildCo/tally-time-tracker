{
  "name": "tally-app",
  "version": "0.1.0",
  "private": true,
  "description": "Tally — automatic time tracking for client billables, built on ActivityWatch",
  "main": "dist-electron/main.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:main": "node scripts/build-main.cjs",
    "export:next": "node scripts/export-electron.cjs",
    "electron:dev": "npm run build:main && concurrently -k \"next dev\" \"wait-on tcp:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "dist": "npm run export:next && npm run build:main && electron-builder"
  },
  "dependencies": {
    "@tremor/react": "^3.18.7",
    "better-sqlite3": "^11.9.1",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.3",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.5"
  }
}
